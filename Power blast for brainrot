local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "Rilzz Hub",
    LoadingTitle = "Rilzz Hub",
    LoadingSubtitle = "Dupe Farm",
    Theme = "Default",
    DisableRayfieldPrompts = false,
    DisableBuildWarnings = false,
})

local Remote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("FuseRequest")
local GiftRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("RequestGiftBrainrot")

local BLACKLIST = { ["Aura"] = true }

-- ========================
-- HELPERS
-- ========================
local function getToolsFromBackpack()
    local backpack = Player:FindFirstChild("Backpack")
    if not backpack then return {} end
    local tools = {}
    for _, v in ipairs(backpack:GetChildren()) do
        if v:IsA("Tool") and not BLACKLIST[v.Name] then
            table.insert(tools, v)
        end
    end
    return tools
end

local function countTools()
    return #getToolsFromBackpack()
end

local function getToolFromBackpack()
    return getToolsFromBackpack()[1]
end

local function equipTool(tool)
    if Player.Character and tool then
        tool.Parent = Player.Character
        task.wait(0.2)
    end
end

local function resetChar()
    local oldChar = Player.Character
    if oldChar and oldChar:FindFirstChild("Humanoid") then
        oldChar.Humanoid.Health = 0
    end
    repeat task.wait() until Player.Character and Player.Character ~= oldChar
    local char = Player.Character
    char:WaitForChild("Humanoid")
    char:WaitForChild("HumanoidRootPart")
    task.wait(1)
end

-- ========================
-- STATE
-- ========================
_G.dupeActive = false
_G.targetPlayer = ""

local playerNames = {}
for _, p in pairs(Players:GetPlayers()) do
    if p ~= Player then
        table.insert(playerNames, p.Name)
    end
end
_G.targetPlayer = playerNames[1] or ""

-- ========================
-- GUI
-- ========================
local MainTab = Window:CreateTab("Main", 4483362458)

if #playerNames > 0 then
    MainTab:CreateDropdown({
        Name = "Target Player",
        Options = playerNames,
        CurrentOption = {playerNames[1]},
        Flag = "target_player",
        Callback = function(val)
            _G.targetPlayer = val[1]
        end
    })
end

MainTab:CreateToggle({
    Name = "Dupe",
    CurrentValue = false,
    Flag = "dupe_toggle",
    Callback = function(val)
        _G.dupeActive = val
    end
})

Players.PlayerAdded:Connect(function(p)
    if p ~= Player then
        table.insert(playerNames, p.Name)
    end
end)

-- ========================
-- DUPE LOOP
-- Alur:
-- Equip+Deposit x4 → Reset → Return x4 → Ulangi sampai tool >= 8
-- Kalau sudah 8 → Gift 7 ke target → Lanjut deposit lagi
-- ========================
coroutine.wrap(function()
    while true do
        task.wait(0.1)
        if not _G.dupeActive then continue end

        pcall(function()
            -- STEP 1: Equip + Deposit x4
            for i = 1, 4 do
                if not _G.dupeActive then return end
                local tool = getToolFromBackpack()
                if not tool then break end
                equipTool(tool)
                Remote:FireServer({ action = "deposit_held" })
                task.wait(0.2)
            end

            if not _G.dupeActive then return end

            -- STEP 2: Reset
            resetChar()

            if not _G.dupeActive then return end

            -- STEP 3: Return x4
            for i = 1, 4 do
                if not _G.dupeActive then return end
                Remote:FireServer({ action = "return_item", index = 1 })
                task.wait(0.2)
            end

            if not _G.dupeActive then return end

            -- STEP 4: Kalau tool belum 8, ulang deposit dulu
            if countTools() < 8 then return end

            -- STEP 5: Sudah 8 tool → Gift 7 ke target (sisakan 1)
            local gifted = 0
            while _G.dupeActive and gifted < 7 do
                local target = Players:FindFirstChild(_G.targetPlayer)
                if not target or not target.Character then
                    task.wait(1)
                    break
                end

                local tools = getToolsFromBackpack()
                if #tools <= 1 then break end

                local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local tween = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {
                            CFrame = targetHRP.CFrame + Vector3.new(3, 0, 0)
                        })
                        tween:Play()
                        tween.Completed:Wait()
                    end
                end
                task.wait(0.1)

                equipTool(tools[1])
                GiftRemote:FireServer(target.UserId)
                gifted = gifted + 1
                task.wait(0.5)
            end

            -- STEP 6: Lanjut deposit lagi (loop ulang otomatis)
        end)
    end
end)()

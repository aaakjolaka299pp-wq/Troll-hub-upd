-- ========================
-- HOOK: Tangkap hasil RequestActiveFlight
-- ========================
-- Delta tidak support hookfunction/replaceclosure per-object.
-- Solusi: hookmetamethod di game (root Instance) untuk intercept semua __namecall,
-- lalu filter khusus yang targetnya RequestActiveFlight:InvokeServer.
_G.LastFlightResult = nil

local hookOk = false

if hookmetamethod then
    hookOk = pcall(function()
        local targetRemote = Network.RequestActiveFlight
        local ClaimFlight = ReplicatedStorage
            :WaitForChild("SharedModules")
            :WaitForChild("Network")
            :WaitForChild("ClaimFlight")

        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if method == "InvokeServer" and self == targetRemote then
                local result = oldNamecall(self, ...)
                if typeof(result) == "table" then
                    _G.LastFlightResult = result

                    -- KLAIM dengan delay kecil supaya server selesai assign brainrot dulu
                    -- Server punya pickupTime ~12 detik, masih banyak waktu
                    -- HANYA brainrot TERAKHIR di array yang valid untuk diklaim (1 per flight)
                    if _G.AutoFarmBrainrots then
                        local capturedTimeInAir = result.timeInAir or 6
                        task.spawn(function()
                            -- Tunggu flight benar2 landed dulu (sama seperti debug yang berhasil)
                            task.wait(capturedTimeInAir + 1)

                            local function claimUID(item)
                                local uid = (typeof(item) == "string") and item
                                    or (typeof(item) == "table" and (item.uid or item.UID or item.id))
                                if not uid then return end
                                local ok, err = pcall(function()
                                    ClaimFlight:InvokeServer(uid)
                                end)
                                task.wait(0.05)
                            end

                            if result.spawnedBrainrots and #result.spawnedBrainrots > 0 then
                                local firstItem = result.spawnedBrainrots[1]
                                claimUID(firstItem)
                            end
                            if result.spawnedCurrencies and #result.spawnedCurrencies > 0 then
                                local firstCurrency = result.spawnedCurrencies[1]
                                claimUID(firstCurrency)
                            end

                            -- Setelah klaim remote selesai, baru cari & fire ProximityPrompt claim fisiknya
                            if _G.PP_FireClaimPrompt then
                                task.wait(0.3)
                                local plr = Players.LocalPlayer
                                local c   = plr.Character
                                local hrp = c and c:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    _G.PP_FireClaimPrompt(hrp)
                                end
                            end
                        end)
                    end
                end
                return result
            end
            return oldNamecall(self, ...)
        end)
    end)
end

if not hookOk then

MainLeft:AddToggle("AutoFarmBrainrotsToggle", {
    Text    = "Auto Farm Brainrots",
    Default  = false,
    Callback = function(state)
        _G.AutoFarmBrainrots = state
        if state then
            task.spawn(function()
                local char = LocalPlayer.Character
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.WalkSpeed = 0
                    hum.JumpPower = 0
                    hum.UseJumpPower = true
                end

                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                _G.SavedPosition = hrp and hrp.CFrame or nil

                -- Ambil LaunchZone terbaik (tower tertinggi di server)
                local lzBest = getBestLaunchZone()
                if lzBest and hrp then
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.CFrame = CFrame.new(lzBest.Position + Vector3.new(0, 5, 0))
                    task.wait(0.5)
                end

                while _G.AutoFarmBrainrots do
                    local okLoop, errLoop = pcall(function()
                        local c    = LocalPlayer.Character
                        local hrp2 = c and c:FindFirstChild("HumanoidRootPart")
                        local hum2 = c and c:FindFirstChildOfClass("Humanoid")

                        if not c or not hrp2 then task.wait(1) return end

                        if hum2 and hum2.WalkSpeed ~= 0 then
                            hum2.WalkSpeed = 0
                            hum2.JumpPower = 0
                        end

                        if ClientCore.IsInFlight or ClientCore.IsInLaunch or ClientCore.IsInCapture then
                            task.wait(0.3)
                            return
                        end

                        -- Selalu update LaunchZone terbaik (bisa berubah kalau ada player baru)
                        local lz = getBestLaunchZone()
                        if not lz then
                            task.wait(0.5)
                            return
                        end

                        -- Pastikan benar-benar berdiri di launch zone sebelum lempar
                        if (hrp2.Position - lz.Position).Magnitude > 5 then
                            hrp2.AssemblyLinearVelocity  = Vector3.zero
                            hrp2.AssemblyAngularVelocity = Vector3.zero
                            hrp2.CFrame = CFrame.new(lz.Position + Vector3.new(0, 5, 0))
                            task.wait(0.5)
                        end


                        if FlightManager then
                            pcall(function() FlightManager:ProcessInput() end)
                        end

                        task.wait(0.45)

                        -- Reset hasil flight sebelumnya sebelum melempar lagi
                        _G.LastFlightResult = nil

                        if hookOk then
                            -- Mode hook: biarkan game manggil RequestActiveFlight sendiri,
                            -- kita cuma menguping hasilnya lewat hook.
                            pcall(function()
                                EventDrivenController.EVENTS.CONTROLLERS.GameplayController.ProcessClick:Fire()
                            end)
                        else
                            -- Mode fallback: kita panggil RequestActiveFlight sendiri duluan
                            -- supaya dapat hasilnya langsung, baru trigger ProcessClick untuk
                            -- animasi/visual lemparan di client.
                            _G.LastFlightResult = ManualRequestActiveFlight(lz)
                            pcall(function()
                                EventDrivenController.EVENTS.CONTROLLERS.GameplayController.ProcessClick:Fire()
                            end)
                        end

                        -- Tunggu sampai benar-benar masuk fase terbang
                        local timeout = tick()
                        while not ClientCore.IsInFlight do
                            if tick() - timeout > 3 then
                                if FlightManager then
                                    pcall(function() FlightManager:CancelLaunch() end)
                                end
                                return
                            end
                            task.wait(0.1)
                        end


                        -- Mode hook: tunggu sampai hasil RequestActiveFlight ke-capture
                        if hookOk then
                            local resultTimeout = tick()
                            while not _G.LastFlightResult do
                                if tick() - resultTimeout > 5 then break end
                                task.wait(0.1)
                            end
                        end

                        local flightResult = _G.LastFlightResult

                        -- Tunggu selesai terbang (pakai timeInAir kalau ada, fallback 10s)
                        local flightDuration = (flightResult and flightResult.timeInAir) or 10
                        local flightTimeout = tick()
                        
                        -- Update FlightManager CONTINUOUSLY selama terbang biar animasi smooth
                        while ClientCore.IsInFlight do
                            if tick() - flightTimeout > (flightDuration + 5) then break end
                            
                            -- Update animasi setiap frame
                            if FlightManager then
                                pcall(function() FlightManager:UpdateInFlight() end)
                            end
                            
                            task.wait(0.016) -- ~60 FPS
                        end

                        ClientCore.IsInFlight = false
                        ClientCore.IsInLaunch = false
                        -- Klaim & fire ProximityPrompt sekarang dipicu otomatis
                        -- setelah ClaimFlight:InvokeServer() berhasil (lihat hook di atas).
                    end)
                    task.wait(0.1)
                end


-- Ambil LaunchZone dengan Y tertinggi (tower tertinggi di server)
local function getBestLaunchZone()
    local CS = game:GetService("CollectionService")
    local zones = CS:GetTagged("LAUNCH_ZONE")
    local best = nil
    local bestY = -math.huge
    for _, zone in ipairs(zones) do
        if zone:IsA("BasePart") and zone.Position.Y > bestY then
            bestY = zone.Position.Y
            best = zone
        end
    end
    return best
end

-- Cari ProximityPrompt terdekat (khusus "Claim" brainrot) dari posisi karakter, lalu teleport + fire
local function isClaimPrompt(obj)
    local name       = (obj.Name or ""):lower()
    local actionText = (obj.ActionText or ""):lower()
    local objectText = (obj.ObjectText or ""):lower()

    if name:find("claim") or actionText:find("claim") or objectText:find("claim") then
        return true
    end

    -- Fallback: prompt yang berada di dalam folder CapturBrainrots
    -- (struktur: Workspace.Live.Debris.CapturBrainrots.<brainrot>.ProximityPrompt)
    local ancestor = obj.Parent
    while ancestor do
        if ancestor.Name == "CapturBrainrots" then
            return true
        end
        ancestor = ancestor.Parent
    end

    return false
end

-- Ambil posisi world dari part/model parent prompt, dengan beberapa fallback
local function getPromptPosition(prompt)
    local part = prompt.Parent
    if not part then return nil end

    if part:IsA("BasePart") then
        return part.Position
    end

    if part:IsA("Model") then
        if part.PrimaryPart then
            return part.PrimaryPart.Position
        end
        local ok, pivot = pcall(function() return part:GetPivot() end)
        if ok and pivot then
            return pivot.Position
        end
        local firstPart = part:FindFirstChildWhichIsA("BasePart", true)
        if firstPart then
            return firstPart.Position
        end
    end

    return nil
end

local function getNearestPrompt(fromPos)
    local nearest, nearestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled and isClaimPrompt(obj) then
            local pos = getPromptPosition(obj)
            if pos then
                local dist = (pos - fromPos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest, nearestDist
end

local function teleportAndFireNearestPrompt(hrp)
    if not hrp then return end
    local prompt, dist = getNearestPrompt(hrp.Position)
    if not prompt then
        return
    end

    local promptPos = getPromptPosition(prompt)
    if not promptPos then
        return
    end

    local targetCFrame = CFrame.new(promptPos + Vector3.new(0, 3, 0))

    -- Teleport beberapa kali berturut-turut untuk lawan reset posisi dari
    -- animasi landing / physics yang mungkin masih jalan sesaat setelah flight.
    for i = 1, 5 do
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = targetCFrame
        task.wait(0.05)
    end

    local actualDist = (hrp.Position - promptPos).Magnitude
    local maxActDist = prompt.MaxActivationDistance or 10

    -- Coba fire beberapa kali, kasih jeda kecil antar percobaan
    for i = 1, 3 do
        local ok, err = pcall(function()
            if fireproximityprompt then
                fireproximityprompt(prompt)
            elseif fireclickdetector then
                -- fallback (jarang dipakai untuk ProximityPrompt, tapi aman dicoba)
                fireclickdetector(prompt)
            else
                error("fireproximityprompt tidak tersedia di executor ini")
            end
        end)
        task.wait(0.1)

        -- Kalau prompt sudah hilang/destroyed setelah fire, berarti claim berhasil
        if not prompt.Parent then
            break
        end
    end
end

_G.PP_FireClaimPrompt = teleportAndFireNearestPrompt

local function ManualRequestActiveFlight()
    local LocalPlr = Players.LocalPlayer
    local char = LocalPlr.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local startPos = hrp and hrp.Position or Vector3.new(0, 0, 0)

    -- Ambil LaunchZone terbaik (Y tertinggi = tower tertinggi)
    local bestZone = getBestLaunchZone()
    local plotIndex  = (bestZone and bestZone:GetAttribute("PlotIndex"))  or 1
    local buildFloors = (bestZone and bestZone:GetAttribute("BuildFloors")) or (ClientCore.Data and ClientCore.Data.BuildFloors) or 1

    -- Fire RequestPendingFlight dulu seperti game ori
    pcall(function()
        SharedNetwork:WaitForChild("RequestPendingFlight"):FireServer()
    end)
    task.wait(0.05)

    local args = {
        plotIndex        = plotIndex,
        intensity        = math.random(),
        serverStrength   = (ClientCore.Data and ClientCore.Data.Strength) or 0,
        player           = LocalPlr,
        visualStartPos   = startPos,
        serverFloors     = buildFloors,
        flightUID        = game:GetService("HttpService"):GenerateGUID(false),
        startTime        = tick(),
        startPos         = startPos,
        serverPickupTime = 30
    }

    local ok, result = pcall(function()
        return SharedNetwork:WaitForChild("RequestActiveFlight"):InvokeServer(args)
    end)

    if ok and typeof(result) == "table" then
        -- Klaim langsung karena pickupTime hanya 12 detik
        task.spawn(function()
            local ClaimFlight = SharedNetwork:WaitForChild("ClaimFlight")
            local function claimUID(item)
                local uid = (typeof(item) == "string") and item
                    or (typeof(item) == "table" and (item.uid or item.UID or item.id))
                if not uid then return end
                pcall(function() ClaimFlight:InvokeServer(uid) end)
                task.wait(0.05)
            end
            if result.spawnedBrainrots then
                for _, item in ipairs(result.spawnedBrainrots) do claimUID(item) end
            end
            if result.spawnedCurrencies then
                for _, item in ipairs(result.spawnedCurrencies) do claimUID(item) end
            end

            -- Setelah klaim remote selesai, baru cari & fire ProximityPrompt claim fisiknya
            if _G.PP_FireClaimPrompt then
                task.wait(0.3)
                local plr = Players.LocalPlayer
                local c   = plr.Character
                local hrp = c and c:FindFirstChild("HumanoidRootPart")
                if hrp then
                    _G.PP_FireClaimPrompt(hrp)
                end
            end
        end)
        return result
    end
    return nil
end


-- Fungsi collect brainrot
function collectNearest()
    hrp.CFrame = CFrame.new(-20.8, 6.2, -3981.8)
    task.wait(1)

    local nearestPrompt = nil
    local nearestPos = nil
    local nearestDistance = math.huge

    local spawnedBrainrots = workspace:FindFirstChild("SpawnedBrainrots")

    if spawnedBrainrots then
        for _, brainrot in ipairs(spawnedBrainrots:GetChildren()) do
            local hitbox = brainrot:FindFirstChild("PickupHitbox")
            if hitbox then
                local prompt = hitbox:FindFirstChildOfClass("ProximityPrompt")
                if prompt then
                    local pos = hitbox.Position
                    local dist = (hrp.Position - pos).Magnitude

                    if dist < nearestDistance then
                        nearestDistance = dist
                        nearestPrompt = prompt
                        nearestPos = pos
                    end
                end
            end
        end
    end

    if nearestPrompt and nearestPos then
        local distance = (hrp.Position - nearestPos).Magnitude

        if distance > 0.5 then
            local direction = (hrp.Position - nearestPos).Unit
            local targetCFrame = CFrame.new(nearestPos + direction * 3)
            local tweenTime = math.max(distance / 50, 0.1)

            local tween = TweenService:Create(
                hrp,
                TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
                {CFrame = targetCFrame}
            )

            tween:Play()
            tween.Completed:Wait()
        end

        nearestPrompt.MaxActivationDistance = 1000
        task.wait(0.1)
        fireproximityprompt(nearestPrompt)

        task.wait(0.5)
        hrp.CFrame = CFrame.new(1.2, 6.4, -245.4)
        task.wait(3)
    end
end

-- Loop Auto Best Area
task.spawn(function()
    while task.wait(0.1) do
        if autoBestArea.state then
            collectNearest()
        end
    end
end)

-- Loop Auto Rebirth
task.spawn(function()
    while task.wait(5) do
        if autoRebirth.state then
            pcall(function()
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("RequestRebirth"):FireServer()
            end)
        end
    end
end)


local processing = {}

local function getBrainrotFolder()
    local GameFolder = workspace:FindFirstChild("GameFolder")
    return GameFolder and GameFolder:FindFirstChild("BrainrotModels")
end

local function hasMutation(model)
    return model:FindFirstChild("MutationHighLight") ~= nil
        or model:FindFirstChild("MutationHighLight", true) ~= nil
end

local function getAllBrainrots()
    local result = {}
    local folder = getBrainrotFolder()
    if folder then
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("Model") then
                result[#result + 1] = child
            end
        end
    end
    if getnilinstances then
        for _, inst in next, getnilinstances() do
            if inst.ClassName == "Model" and #inst.Name == 36 then
                result[#result + 1] = inst
            end
        end
    end
    return result
end

local function getBackpackBrainrots()
    local result = {}
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if not Backpack then return result end
    for _, tool in ipairs(Backpack:GetChildren()) do
        if #tool.Name == 36 then
            result[#result + 1] = tool.Name
        end
    end
    return result
end

local function unequipAll()
    for i = 1, 100 do
        pcall(function()
            UnlockSlot:FireServer(i)
        end)
    end
end

local function placeAll()
    local brainrots = getBackpackBrainrots()
    for i = 1, 100 do
        local name = brainrots[i]
        if name then
            pcall(function()
                UpgradeBrainrot:FireServer(name)
            end)
            task.wait(0.05)
        end
    end
end

-- ========================
-- SNIPE FUNCTION (Fix gal52)
-- ========================
local function snipeBrainrot(model)
    local Name = model.Name
    pcall(function()
        BrainrotAttack:FireServer(Name)
    end)
    task.wait(0.03)

    local droneUid = nil
    for i = 1, 8 do
        local ok, result = pcall(function()
            return DroneRequest:InvokeServer({
                startPos   = startPos,
                endPos     = endPos,
                startTick  = tick(),
                brainrotUid = Name
            })
        end)
        if ok and result then
            if type(result) == "string" then
                droneUid = result
            elseif type(result) == "table" then
                droneUid = result.droneUid or result.DroneUid or (Name .. "Drone")
            end
            if droneUid then break end
        end
        task.wait(0.05)
    end

    if not droneUid then return false end

    for i = 1, 4 do
        local ok2 = pcall(function()
            return DroneCapture:InvokeServer(Name, droneUid)
        end)
        if ok2 then
            pcall(function() DroneClaim:FireServer(droneUid) end)
            return true
        end
        task.wait(0.05)
    end

    pcall(function() DroneClaim:FireServer(droneUid) end)
    return true
end

-- ========================
-- AUTO CLAIM LOOP (Fix gal63)
-- ========================
task.spawn(function()
    while true do
        if State.InstantClaim then
            local mutationOnly = State.ClaimMode == "Random Mutation"
            for _, model in ipairs(getAllBrainrots()) do
                if not processing[model.Name] then
                    local shouldClaim = not mutationOnly or hasMutation(model)
                    if shouldClaim then
                        processing[model.Name] = true
                        task.spawn(function()
                            pcall(snipeBrainrot, model)
                            processing[model.Name] = nil
                        end)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)


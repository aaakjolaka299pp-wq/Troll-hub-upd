    -- gal50: Result checker
    local function gal50(result)
        if type(result) == "table" then
            return result.success == true, result.reason
        end
        return result ~= nil and result ~= false
    end

    -- gal51: Extract droneUid
    local function gal51(result, fallback)
        if type(result) == "string" then return result end
        if type(result) == "table" then
            local uid = result.droneUid or result.DroneUid or result.drone
                     or result.droneId or result.uid or result.id or result.Drone
            if type(uid) == "string" then return uid end
        end
        return fallback .. "Drone"
    end

    -- gal52: Snipe brainrot (FIXED - broken loop/undefined vars removed)
    local function gal52(model)
        local Name = model.Name

        pcall(function() gal38:FireServer(Name) end)
        task.wait(0.03)

        local droneResult = nil
        for i = 1, 8 do
            local ok, result = pcall(function()
                return gal39:InvokeServer({
                    startPos    = gal48,
                    endPos      = gal49,
                    startTick   = tick(),
                    brainrotUid = Name
                })
            end)
            if ok and result then
                droneResult = result
                break
            end
            task.wait(0.05)
        end

        if not droneResult then return false end

        local droneUid = gal51(droneResult, Name)

        for i = 1, 4 do
            local ok = pcall(function()
                return gal40:InvokeServer(Name, droneUid)
            end)
            if ok then
                pcall(function() gal41:FireServer(droneUid) end)
                return true
            end
            task.wait(0.05)
        end

        pcall(function() gal41:FireServer(droneUid) end)
        return true
    end


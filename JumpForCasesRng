-- ========================
-- TAB: FARM
-- ========================
local FarmLeft = Tabs.Farm:AddLeftGroupbox("Auto Farm Loop", "zap")

local targetPos = Vector3.new(206.8, 23.9, 103.4)
local hasFiredKick = false

-- Thread Khusus Cutscene Detection (Persis sesuai kodenya)
task.spawn(function()
    local wasKicking = false
    while true do
        if Toggles["AutoFarm"] and Toggles["AutoFarm"].Value then
            local isKicking = LocalPlayer:GetAttribute("_IsKicking")
            if isKicking == nil then
                isKicking = LocalPlayer:GetAttribute("IsKicking")
            end

            if wasKicking and not isKicking then
                task.wait(0.1)
                for i = 1, 3 do
                    local args2 = { { kind = "waveCutsceneDone" } }
                    fallReward:FireServer(unpack(args2))
                    task.wait(0.05)
                end
            end

            wasKicking = isKicking or false
        else
            wasKicking = false
        end
        task.wait(0.05)
    end
end)

-- Toggle & Loop Auto Farm
FarmLeft:AddToggle("AutoFarm", {
    Text    = "Auto Farm",
    Default = false,
    Tooltip = "Auto walk ke target & fire requestKick saat dekat",
    Callback = function(state)
        if state then
            startLoop("AutoFarm", function()
                local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local humanoid  = character:FindFirstChildOfClass("Humanoid")
                local hrp       = character:FindFirstChild("HumanoidRootPart")

                if humanoid and hrp and humanoid.Health > 0 then
                    local distance = (hrp.Position - targetPos).Magnitude

                    humanoid:MoveTo(targetPos)

                    if distance <= 4 then
                        if not hasFiredKick then
                            hasFiredKick = true
                            local args1 = { { tier = "Perfect" } }
                            requestKick:FireServer(unpack(args1))
                        end
                    else
                        hasFiredKick = false
                    end
                else
                    hasFiredKick = false
                end
            end, function() return Options.AutoFarmDelay and Options.AutoFarmDelay.Value or 0.05 end)
        else
            stopLoop("AutoFarm")
            hasFiredKick = false
        end
    end,
})


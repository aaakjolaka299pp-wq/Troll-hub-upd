-- ========================
-- COLLECT CASH (stand 1-40)
-- ========================
local function doCollect()
    local AnimalStands = Player:FindFirstChild("AnimalStands")
    if not AnimalStands then return end
    local CollectCash = ReplicatedStorage:FindFirstChild("Events")
        and ReplicatedStorage.Events:FindFirstChild("CollectCash")
    if not CollectCash then return end
    for i = 1, 40 do
        if not AutoCollect then break end
        local stand = AnimalStands:FindFirstChild(tostring(i))
        if stand then
            pcall(function() CollectCash:FireServer(stand) end)
        end
        task.wait(0.05)
    end
end

-- ========================
-- HELPER
-- ========================
local function getValidTool(bag)
    for _, t in ipairs(bag:GetChildren()) do
        if t:IsA("Tool") then
            local tip = (t.ToolTip or ""):lower()
            local nm  = t.Name:lower()
            if not string.find(tip, "treadmill") and not string.find(nm, "treadmill") then
                return t
            end
        end
    end
    return nil
end

-- ========================
-- FUSE (FuseMachine)
-- ========================
local function doFuse()
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local HRP       = Character:WaitForChild("HumanoidRootPart")
    local Humanoid  = Character:WaitForChild("Humanoid")

    local ok = pcall(function()
        local Part = workspace.Map.FuseMachine.AddPrompt.ProximityPrompt.Parent
        HRP.CFrame = Part.CFrame + Vector3.new(0, 0, -3)
    end)
    if not ok then return end
    task.wait(0.1)

    local Tool = getValidTool(Player.Backpack)
    if Tool then
        Humanoid:EquipTool(Tool)
        task.wait(0.2)
    end

    local FuseRetrieve = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FuseRetrieve")
    for i = 1, 4 do
        pcall(function()
            local args = { i }
            FuseRetrieve:FireServer(unpack(args))
        end)
        task.wait(0.05)
    end

    task.wait(0.1)
    Character:BreakJoints()
    task.wait(1)

    local NewCharacter = Player.Character or Player.CharacterAdded:Wait()
    local NewHRP       = NewCharacter:WaitForChild("HumanoidRootPart")
    local NewHumanoid  = NewCharacter:WaitForChild("Humanoid")

    local NearestPrompt, NearestDistance = nil, math.huge
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt")
            and (v.ActionText == "Insert Brainrot" or v.ObjectText == "Insert Brainrot") then
            local p = v.Parent
            if p and p:IsA("BasePart") then
                local d = (NewHRP.Position - p.Position).Magnitude
                if d < NearestDistance then
                    NearestDistance = d
                    NearestPrompt   = v
                end
            end
        end
    end

    if NearestPrompt then
        local tf = tick()
        while tick() - tf < 5 do
            if not AutoFuse then break end
            local t = getValidTool(Player.Backpack)
            if t then
                pcall(function() NewHumanoid:EquipTool(t) end)
                task.wait(0.1)
            end
            pcall(function() fireproximityprompt(NearestPrompt) end)
            task.wait(0.2)
        end
    end

    pcall(function()
        local char = Player.Character or Player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        hrp.CFrame = CFrame.new(Vector3.new(48.1, 4.2, -7.5))
    end)
end


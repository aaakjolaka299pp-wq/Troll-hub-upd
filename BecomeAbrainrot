-- PING UPDATER
-- ========================
task.spawn(function()
    while ScreenGui.Parent do
        local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
        PingLabel.Text = "Ping: " .. ping .. "ms"
        if ping < 100 then
            PingLabel.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
        elseif ping < 200 then
            PingLabel.BackgroundColor3 = Color3.fromRGB(220, 140, 0)
        else
            PingLabel.BackgroundColor3 = Color3.fromRGB(255, 40, 70)
        end
        task.wait(2)
    end
end)

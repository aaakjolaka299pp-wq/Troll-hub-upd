-- Build tool options dynamic dari backpack
local function buildToolOptions()
    for _, c in ipairs(toolScroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local opts = {"All"}
    local n = 0
    for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if t:IsA("Tool") then
            local tip = (t.ToolTip or ""):lower()
            local nm  = t.Name:lower()
            if not string.find(tip, "treadmill") and not string.find(nm, "treadmill") then
                n = n + 1
            end
        end
    end
    -- tambah tool equipped
    if LocalPlayer.Character then
        local eq = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if eq then
            local tip = (eq.ToolTip or ""):lower()
            local nm  = eq.Name:lower()
            if not string.find(tip, "treadmill") and not string.find(nm, "treadmill") then
                n = n + 1
            end
        end
    end
    for i = 1, n do
        table.insert(opts, tostring(i))
    end
    for _, opt in ipairs(opts) do
        local btn = Instance.new("TextButton", toolScroll)
        btn.Size = UDim2.new(1, 0, 0, 30)
        btn.BackgroundTransparency = 1
        btn.Text = "  " .. opt
        btn.TextColor3 = Color3.fromRGB(220, 220, 230)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.ZIndex = 8
        btn.MouseButton1Click:Connect(function()
            TrdState.selectedCount = opt
            toolValLbl.Text = opt
            closeToolDrop()
        end)
    end
    toolScroll.CanvasSize = UDim2.new(0, 0, 0, #opts * 32)
    return math.min(#opts * 32, 120), n
end


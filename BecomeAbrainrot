-- ========================
-- TELEPORT
-- ========================
local function doTeleport(pos)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    hrp.CFrame = CFrame.new(pos)
end

local function doTpBestArea()
    pcall(function()
        doTeleport(Vector3.new(50.5, 2.1, -16.2))
        task.wait(1)
        doTeleport(Vector3.new(43.6, 2.7, -1453.7))
    end)
end

local function doTpSpawn()
    pcall(function()
        doTeleport(Vector3.new(48.1, 4.2, -7.5))
    end)
end


local function selectTab(name)
    if activeTab == name then return end
    activeTab = name
    for n, data in pairs(tabs) do
        local isActive = (n == name)
        data.btn.BackgroundTransparency = isActive and 0.4 or 1
        data.lbl.TextColor3 = isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(160,160,170)
        data.bar.BackgroundTransparency = isActive and 0 or 1
    end
    for n, content in pairs(contents) do
        content.Visible = (n == name)
    end
end


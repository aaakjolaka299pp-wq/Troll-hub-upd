local function doTRD()
    if not TrdState.selectedPlayer then return end
    local targetPlayer = game:GetService("Players"):FindFirstChild(TrdState.selectedPlayer)
    if not targetPlayer then return end
    local RequestGift = ReplicatedStorage:WaitForChild("Events"):WaitForChild("RequestGift")
    local count
    if TrdState.selectedCount == "Any" then
        local n = 0
        for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if t:IsA("Tool") then
                local tip = (t.ToolTip or ""):lower()
                local nm  = t.Name:lower()
                if not string.find(tip, "treadmill") and not string.find(nm, "treadmill") then
                    n = n + 1
                end
            end
        end
        count = n
    else
        count = tonumber(TrdState.selectedCount) or 1
    end
    for i = 1, count do
        if not trdRunning then break end
        local char = LocalPlayer.Character
        if not char then break end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local tool = getValidTool(LocalPlayer.Backpack)
        if tool and hum then
            pcall(function() hum:EquipTool(tool) end)
            task.wait(0.1)
        end
        pcall(function() RequestGift:FireServer(targetPlayer) end)
        task.wait(0.2)
    end
end

trdSwitchBg.MouseButton1Click:Connect(function()
    trdRunning = not trdRunning
    TweenService:Create(trdCircle, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = trdRunning and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
    }):Play()
    TweenService:Create(trdSwitchBg, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        BackgroundColor3 = trdRunning and Color3.fromRGB(52, 199, 89) or Color3.fromRGB(45, 45, 55)
    }):Play()
    if trdRunning then
        task.spawn(function()
            while trdRunning do
                pcall(doTRD)
                task.wait(0.1)
            end
        end)
    end
end)


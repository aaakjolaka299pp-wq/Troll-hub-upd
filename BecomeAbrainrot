local function stopTRD()
    trdRunning = false
    TweenService:Create(trdCircle, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 3, 0.5, -10)
    }):Play()
    TweenService:Create(trdSwitchBg, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    }):Play()
end

local function doTRD()
    if not TrdState.selectedPlayer then return end
    local targetPlayer = game:GetService("Players"):FindFirstChild(TrdState.selectedPlayer)
    if not targetPlayer then return end
    local RequestGift = ReplicatedStorage:WaitForChild("Events"):WaitForChild("RequestGift")

    -- Hitung jumlah awal tool sebelum mulai
    local toolsBefore = countValidTools()

    -- Tentukan berapa yang mau dikirim
    local sendCount
    if TrdState.selectedCount == "All" then
        sendCount = toolsBefore
    else
        sendCount = tonumber(TrdState.selectedCount) or 1
    end

    -- Target sisa tool setelah selesai
    local targetRemaining = toolsBefore - sendCount

    while trdRunning do
        local currentTools = countValidTools()
        -- Stop kalau sisa tool udah sesuai target
        if currentTools <= targetRemaining then
            break
        end

        local char = LocalPlayer.Character
        if not char then break end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local tool = getValidTool(LocalPlayer.Backpack)
        if tool and hum then
            pcall(function() hum:EquipTool(tool) end)
            task.wait(0.1)
        end
        pcall(function() RequestGift:FireServer(targetPlayer) end)
        task.wait(0.3)
    end

    stopTRD()
end


-- ========================
-- DRAG
-- ========================
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        State.isDragging = true
        State.dragStart = input.Position
        State.startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                State.isDragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if State.isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - State.dragStart
        MainFrame.Position = UDim2.new(
            State.startPos.X.Scale, State.startPos.X.Offset + delta.X,
            State.startPos.Y.Scale, State.startPos.Y.Offset + delta.Y
        )
    end
end)

-- ========================
-- MINIMIZE / RESTORE
-- ========================
MinBtn.MouseButton1Click:Connect(function()
    if State.isAnimating then return end
    State.isAnimating = true
    local savedSize = MainFrame.Size
    local savedPos  = MainFrame.Position
    TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = MiniWidget.Position
    }):Play()
    task.wait(0.3)
    MainFrame.Visible = false
    MiniWidget.Visible = true
    MiniWidget.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(MiniWidget, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 42, 0, 42)
    }):Play()
    task.wait(0.3)
    State.isAnimating = false
    MainFrame.Size = savedSize
    MainFrame.Position = savedPos
end)

MiniWidget.MouseButton1Click:Connect(function()
    if State.isAnimating then return end
    State.isAnimating = true
    TweenService:Create(MiniWidget, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    }):Play()
    task.wait(0.15)
    MiniWidget.Visible = false
    MainFrame.Visible = true
    local targetSize = MainFrame.Size
    local targetPos  = MainFrame.Position
    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.Position = MiniWidget.Position
    TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = targetSize,
        Position = targetPos
    }):Play()
    task.wait(0.4)
    State.isAnimating = false
end)


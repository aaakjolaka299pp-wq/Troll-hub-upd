local function getValidTool(bag)
    for _, t in ipairs(bag:GetChildren()) do
        if t:IsA("Tool") then
            local tip = (t.ToolTip or ""):lower()
            local nm  = t.Name:lower()
            if not string.find(tip, "treadmill") and not string.find(nm, "treadmill") then
                return t
            end
        end
    end
    return nil
end

local function getNearestInsertPrompt(hrp)
    local nearest, nearestDist = nil, math.huge
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt")
            and (v.ActionText == "Insert Brainrot" or v.ObjectText == "Insert Brainrot") then
            local p = v.Parent
            if p and p:IsA("BasePart") then
                local d = (hrp.Position - p.Position).Magnitude
                if d < nearestDist then
                    nearestDist = d
                    nearest = v
                end
            end
        end
    end
    return nearest
end

-- COLLECT CASH
local function doCollect()
    local AnimalStands = LocalPlayer:FindFirstChild("AnimalStands")
    if not AnimalStands then return end
    local CollectCash = ReplicatedStorage:FindFirstChild("Events")
        and ReplicatedStorage.Events:FindFirstChild("CollectCash")
    if not CollectCash then return end
    for i = 1, 40 do
        if not State.AutoCollect then break end
        local stand = AnimalStands:FindFirstChild(tostring(i))
        if stand then
            pcall(function() CollectCash:FireServer(stand) end)
        end
        task.wait(0.05)
    end
end

-- FUSE (FuseMachine)
local function doFuse()
    local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local HRP       = Character:WaitForChild("HumanoidRootPart")
    local Humanoid  = Character:WaitForChild("Humanoid")

    local ok = pcall(function()
        local Part = workspace.Map.FuseMachine.AddPrompt.ProximityPrompt.Parent
        HRP.CFrame = Part.CFrame + Vector3.new(0, 0, -3)
    end)
    if not ok then return end
    task.wait(0.1)

    local Tool = getValidTool(LocalPlayer.Backpack)
    if Tool then
        Humanoid:EquipTool(Tool)
        task.wait(0.2)
    end

    local FuseRetrieve = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FuseRetrieve")
    for i = 1, 4 do
        pcall(function() FuseRetrieve:FireServer(i) end)
        task.wait(0.05)
    end

    task.wait(0.1)
    Character:BreakJoints()

    -- Tunggu karakter baru
    local NewCharacter = LocalPlayer.Character
    if not NewCharacter or NewCharacter == Character then
        local done = false
        local conn
        conn = LocalPlayer.CharacterAdded:Connect(function(c)
            NewCharacter = c
            done = true
            conn:Disconnect()
        end)
        local t0 = tick()
        while not done do
            if not State.AutoFuse then conn:Disconnect() return end
            if tick() - t0 > 10 then conn:Disconnect() return end
            task.wait(0.05)
        end
    end

    local NewHRP      = NewCharacter:WaitForChild("HumanoidRootPart")
    local NewHumanoid = NewCharacter:WaitForChild("Humanoid")

    -- Tunggu fully loaded
    local h0 = tick()
    while NewHumanoid.Health <= 0 do
        if not State.AutoFuse then return end
        if tick() - h0 > 5 then return end
        task.wait(0.05)
    end

    if not State.AutoFuse then return end

    local NearestPrompt = getNearestInsertPrompt(NewHRP)
    if not NearestPrompt then return end

    local t = getValidTool(LocalPlayer.Backpack)
    if t then pcall(function() NewHumanoid:EquipTool(t) end) end
    pcall(function() fireproximityprompt(NearestPrompt) end)

    local FuseRetrieve2 = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FuseRetrieve")
    for i = 1, 4 do
        pcall(function() FuseRetrieve2:FireServer(i) end)
    end
end


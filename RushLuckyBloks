-- ========================
-- AUTO MOBS - LOGIC UTAMA
-- ========================
local function startMobs()
    task.spawn(function()
        while getgenv().AutoMobs do
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local Bosses = workspace:FindFirstChild("Bosses")
                if not Bosses then return end

                local nearest = nil
                local nearestDist = math.huge

                for _, mob in ipairs(Bosses:GetDescendants()) do
                    if mob:IsA("Model") and mob:FindFirstChild("HumanoidRootPart") then
                        local dist = (mob.HumanoidRootPart.Position - hrp.Position).Magnitude
                        if dist < nearestDist then
                            nearestDist = dist
                            nearest = mob.HumanoidRootPart
                        end
                    end
                end

                -- UPDATE POSISI SETIAP 0.1 DETIK (TANPA KONDISI YANG BIKIN HANG)
                if nearest then
                    local offset
                    if mobPosition == "Above" then
                        offset = Vector3.new(0, setDistance, 0)
                        hrp.Anchored = true
                        hrp.CFrame = CFrame.lookAt(
                            nearest.Position + offset,
                            nearest.Position
                        )
                    elseif mobPosition == "Front" then
                        offset = Vector3.new(0, 0, setDistance)
                        hrp.Anchored = true
                        hrp.CFrame = CFrame.lookAt(
                            nearest.Position + offset,
                            nearest.Position
                        )
                    end
                end
            end)
            task.wait(0.1)
        end

        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false end
    end)
end

TabFight:CreateToggle({
    Name         = "Auto Mobs",
    CurrentValue = false,
    Callback     = function(v)
        getgenv().AutoMobs = v
        if v then
            startMobs()
        else
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Anchored = false end
        end
    end
})


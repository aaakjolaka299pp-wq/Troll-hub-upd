-- ========================
-- COLLECT CASH
-- ========================
Main:CreateToggle({
    Name = "Collect Cash",
    CurrentValue = false,
    Callback = function(v)
        getgenv().CollectCash = v
        task.spawn(function()
            while getgenv().CollectCash and not destroying do
                pcall(function()
                    local hrp = getHRP()
                    if not hrp then return end
                    local Plots = Workspace:FindFirstChild("Plots")
                    if not Plots then return end
                    for _, plotFolder in pairs(Plots:GetChildren()) do
                        for _, plotModel in pairs(plotFolder:GetChildren()) do
                            local containers = plotModel:FindFirstChild("Containers")
                            if containers then
                                for _, slot in pairs(containers:GetChildren()) do
                                    for _, inner in pairs(slot:GetChildren()) do
                                        local collection = inner:FindFirstChild("Collection")
                                        if collection then
                                            local pad = collection:FindFirstChild("CollectionPad")
                                            if pad and pad:IsA("BasePart") then
                                                firetouchinterest(hrp, pad, 0)
                                                firetouchinterest(hrp, pad, 1)
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
    end
})

-- ========================
-- GOD MODE
-- ========================
local function applyToCharacter(character)
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.MaxHealth = math.huge
        humanoid.Health = math.huge
    end
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = false
            part.CanQuery = false
        end
    end
end

local function enableGodMode()
    if LocalPlayer.Character then
        applyToCharacter(LocalPlayer.Character)
    end
    local conn = LocalPlayer.CharacterAdded:Connect(function(character)
        task.wait(0.5)
        applyToCharacter(character)
    end)
    table.insert(godConnections, conn)
    task.spawn(function()
        while getgenv().GodMode do
            pcall(function()
                local humanoid = LocalPlayer.Character
                    and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.MaxHealth = math.huge
                    humanoid.Health = math.huge
                end
            end)
            task.wait(0.1)
        end
    end)
end

local function disableGodMode()
    for _, conn in ipairs(godConnections) do
        conn:Disconnect()
    end
    godConnections = {}
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.MaxHealth = 100
            humanoid.Health = 100
        end
    end
end

Main:CreateToggle({
    Name = "God Mode",
    CurrentValue = false,
    Callback = function(v)
        getgenv().GodMode = v
        if v then enableGodMode() else disableGodMode() end
    end
})


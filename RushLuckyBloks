-- BONUS TRAIN / x2 Train (copy persis dari original startTrain)
-- ========================
local function startTrain()
    task.spawn(function()
        while getgenv().BonusTrain do
            pcall(function()
                local char = LocalPlayer.Character
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                local backpack = LocalPlayer:FindFirstChild("Backpack")
                if not humanoid or not backpack then return end

                for _, tool in ipairs(backpack:GetChildren()) do
                    if tool:IsA("Tool") and tool:GetAttribute("TrainToolType") ~= nil then
                        humanoid:EquipTool(tool)
                        break
                    end
                end

                local btn = LocalPlayer.PlayerGui:FindFirstChild("SpeedEffect")
                if not btn then return end
                btn = btn:FindFirstChild("LeftContainer")
                if not btn then return end
                btn = btn:FindFirstChild("Currency")
                if not btn then return end
                btn = btn:FindFirstChild("Speed")
                if not btn then return end
                btn = btn:FindFirstChild("x2Speed")
                if not btn then return end

                if btn.Visible then
                    local realBtn = btn:FindFirstChild("Button")
                    if realBtn then
                        for _, conn in pairs(getconnections(realBtn.Activated)) do
                            pcall(function() conn.Function() end)
                        end
                    end
                end
            end)
            task.wait(0.1)
        end

        pcall(function()
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):UnequipTools()
        end)
    end)
end


-- AUTO FARM
local TweenService   = game:GetService("TweenService")
local tpToGuard      = RemoteFolder:WaitForChild("game.yeet.tpToGuard")
local throwRemote    = RemoteFolder:WaitForChild("game.yeet.throw")
local farmTargetPos  = Vector3.new(-32.9, 33.1, -296.9)
local farmDelay      = 0.1
local farmTweenSpeed = 30
local farmThread     = nil
local farmRemoteThread = nil

MainLeft:AddToggle("AutoFarm", {
    Text    = "Auto Farm",
    Default = false,
    Tooltip = "Auto farm: Tween ke target + spam remote tpToGuard & throw",
    Callback = function(state)
        if state then
            -- Loop remote (background)
            farmRemoteThread = task.spawn(function()
                while Toggles["AutoFarm"] and Toggles["AutoFarm"].Value do
                    pcall(function()
                        tpToGuard:InvokeServer()
                        throwRemote:InvokeServer(1)
                    end)
                    local d = farmDelay
                    if d <= 0 then task.wait() else task.wait(d) end
                end
            end)
            -- Loop tween (utama)
            farmThread = task.spawn(function()
                while Toggles["AutoFarm"] and Toggles["AutoFarm"].Value do
                    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                    local hrp  = char:WaitForChild("HumanoidRootPart", 5)
                    if hrp then
                        local dist  = (hrp.Position - farmTargetPos).Magnitude
                        local speed = farmTweenSpeed > 0 and farmTweenSpeed or 30
                        local tween = TweenService:Create(
                            hrp,
                            TweenInfo.new(dist / speed, Enum.EasingStyle.Linear),
                            { CFrame = CFrame.new(farmTargetPos) }
                        )
                        tween:Play()
                        tween.Completed:Wait()
                    end
                    task.wait()
                end
            end)
        else
            if farmThread then task.cancel(farmThread) farmThread = nil end
            if farmRemoteThread then task.cancel(farmRemoteThread) farmRemoteThread = nil end
        end
    end,
})
MainLeft:AddSlider("AutoFarmDelay", {
    Text     = "Auto Farm Delay",
    Default  = 0.1, Min = 0, Max = 5, Rounding = 1, Suffix = "s",
    Callback = function(val) farmDelay = val end,
})
MainLeft:AddInput("AutoFarmSpeed", {

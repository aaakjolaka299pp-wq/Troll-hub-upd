-- ========================
-- DUPE LOOP
-- ========================
coroutine.wrap(function()
    while true do
        task.wait(0.1)
        if not _G.dupe then continue end

        pcall(function()
            local myLot = getMyLot()
            if not myLot then return end

            -- PHASE 1: PLACE
            while _G.dupe do
                local placePrompt = getNearestPrompt("Place Item")
                if not placePrompt then break end

                -- Tween ke prompt
                local pos = getPromptPosition(placePrompt)
                if pos then tweenTo(CFrame.new(pos)) end
                task.wait(0.1)

                -- Equip tool
                local tool = getBrainrotTool()
                if not tool then break end

                local char = player.Character or player.CharacterAdded:Wait()
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid:EquipTool(tool)
                    task.wait(0.1)
                end

                -- Kill
                local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = 0 end

                -- Tunggu respawn
                waitForRespawn()

                -- Tween ke prompt lagi
                local freshPrompt = getNearestPrompt("Place Item")
                if not freshPrompt then break end

                local freshPos = getPromptPosition(freshPrompt)
                if freshPos then tweenTo(CFrame.new(freshPos)) end
                task.wait(0.1)

                -- Fire place
                fireproximityprompt(freshPrompt)
                task.wait(0.5)
            end

            -- PHASE 2: PICKUP
            while _G.dupe do
                local pickupPrompt = getNearestPrompt("Pick Up")
                if not pickupPrompt then break end

                local pos = getPromptPosition(pickupPrompt)
                if pos then tweenTo(CFrame.new(pos) + Vector3.new(0, 3, 0)) end
                task.wait(0.1)

                fireproximityprompt(pickupPrompt)
                task.wait(0.2)

                task.wait(0.1)
                unequipBrainrot()
            end
        end)
    end
end)()

-- ========================
-- AUTO COLLECT CASH
-- ========================
coroutine.wrap(function()
    while true do
        task.wait(1)
        if not _G.autoCash then continue end
        pcall(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local plot = getMyLot()
            if not plot then return end
            for _, obj in pairs(plot:GetDescendants()) do
                if obj.Name == "CollectTouch" or obj.Name == "Collect_Under" then
                    firetouchinterest(hrp, obj, 0)
                    task.wait(0.05)
                    firetouchinterest(hrp, obj, 1)
                end
            end
        end)
    end
end)()


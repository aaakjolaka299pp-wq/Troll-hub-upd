-- ========================
-- HELPERS
-- ========================
local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function getMyLot()
    return workspace:FindFirstChild("Plot_" .. player.Name)
end

local function tweenTo(targetCFrame)
    local hrp = getHRP()
    if not hrp then return end
    local tween = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {
        CFrame = targetCFrame
    })
    tween:Play()
    tween.Completed:Wait()
end

local function getBrainrotTool()
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return nil end
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and not tool.Name:lower():find("aura") and not tool.Name:lower():find("log") then
            return tool
        end
    end
    local char = player.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") and not tool.Name:lower():find("aura") and not tool.Name:lower():find("log") then
                return tool
            end
        end
    end
    return nil
end

local function getNearestPrompt(actionText)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local nearestPrompt = nil
    local shortestDistance = math.huge

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled and v.ActionText == actionText then
            if v.ObjectText:lower():find("swap") or v.ActionText:lower():find("swap") or v.Parent.Name:lower():find("swap") then
                continue
            end

            local parent = v.Parent
            local pos

            if parent:IsA("BasePart") then
                pos = parent.Position
            elseif parent:IsA("Attachment") and parent.Parent:IsA("BasePart") then
                pos = parent.WorldPosition
            end

            if pos then
                local dist = (hrp.Position - pos).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    nearestPrompt = v
                end
            end
        end
    end

    return nearestPrompt
end

local function unequipBrainrot()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and not tool.Name:lower():find("aura") and not tool.Name:lower():find("log") then
            humanoid:UnequipTools()
            return
        end
    end
end

local function getPromptPosition(prompt)
    local parent = prompt.Parent
    if parent:IsA("BasePart") then
        return parent.Position
    elseif parent:IsA("Attachment") and parent.Parent:IsA("BasePart") then
        return parent.Parent.Position
    end
    return nil
end

local function waitForRespawn()
    repeat task.wait(0.05) until Players.LocalPlayer
    local p = Players.LocalPlayer
    local newChar = p.Character
    if not newChar or not newChar.Parent then
        newChar = p.CharacterAdded:Wait()
    end
    repeat task.wait(0.05) until newChar:FindFirstChild("HumanoidRootPart") and newChar:FindFirstChild("Humanoid")
    task.wait(0.15)
end


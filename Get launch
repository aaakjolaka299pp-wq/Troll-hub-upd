-- AUTO TRAIN
-- ========================
local function HookTap(obj)
    if obj.Name ~= "TrainingLogTapPrompt" then return end
    task.spawn(function()
        while obj and obj.Parent do
            if not _G.autoTrain then task.wait(0.1) continue end
            if obj.Visible then
                pcall(function()
                    for _, conn in pairs(getconnections(obj.Activated)) do
                        conn.Function()
                    end
                    for _, conn in pairs(getconnections(obj.MouseButton1Click)) do
                        conn.Function()
                    end
                end)
                task.wait(0.05)
            else
                task.wait(0.1)
            end
        end
    end)
end

HUD.DescendantAdded:Connect(HookTap)
for _, v in pairs(HUD:GetDescendants()) do HookTap(v) end


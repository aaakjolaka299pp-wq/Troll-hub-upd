-- AUTO CLAIM BONUS
local selectedBonus = {}

local function clickBonusButton()
    pcall(function()
        local popUpGui = LocalPlayer.PlayerGui:FindFirstChild("PopUpGui")
        if not popUpGui then return end
        local btn = popUpGui:FindFirstChild("StrenghPopup", true)
        if btn then
            local pos = btn.AbsolutePosition
            local size = btn.AbsoluteSize
            local center = Vector2.new(pos.X + size.X / 2, pos.Y + size.Y / 2)
            -- Simulasi mouse click di posisi tengah button
            local inputService = game:GetService("UserInputService")
            local mouse = LocalPlayer:GetMouse()
            mouse.Button1Down:Fire()
            task.wait(0.05)
            mouse.Button1Up:Fire()
        end
    end)
end

MainRight:AddDropdown("BonusSelector", {
    Values   = { "x2", "x4", "x10" },

    Callback = function(val) selectedBonus = val end,
})
MainRight:AddToggle("AutoClaimBonus", {
    Text    = "Auto Claim Bonus",
    Default = false,
    Tooltip = "Auto claim bonus x2/x4/x10",
    Callback = function(state)
        if state then

-- AUTO FARM
local function doAction()
    local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local HRP = Character:WaitForChild("HumanoidRootPart")

    -- 1. Teleport Awal
    HRP.CFrame = CFrame.new(-45.0, 33.2, -305.9)
    task.wait()

    -- 2. TP Guard
    RemoteFolder:WaitForChild("game.yeet.tpToGuard"):InvokeServer()
    task.wait()

    -- 3. Throw V1
    RemoteFolder:WaitForChild("game.yeet.throw"):InvokeServer(0.9070215386371794)
    task.wait()

    -- 4. Throw V2
    RemoteFolder:WaitForChild("game.yeet.throw"):InvokeServer()
    task.wait()

    -- 5. Teleport Baru
    HRP.CFrame = CFrame.new(3919.1, 36.1, -294.6)
    task.wait()
end

MainLeft:AddToggle("AutoFarm", {
    Text    = "Auto Farm",
    Default = false,
    Tooltip = "Auto farm loop: TP → Guard → Throw → TP",
    Callback = function(state)
        if state then
            startLoop("AutoFarm", function()
                doAction()
            end, function() return 0 end)
        else
            stopLoop("AutoFarm")
        end
    end,
})


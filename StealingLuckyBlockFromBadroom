-- =============================================
--  LOOP HELPER
-- =============================================
local threads = {}

local function startLoop(key, fn, getDelay)
    if threads[key] then task.cancel(threads[key]) threads[key] = nil end
    threads[key] = task.spawn(function()
        while Toggles[key] and Toggles[key].Value do
            pcall(fn)
            local d = getDelay and getDelay() or 0.5
            if d <= 0 then task.wait() else task.wait(d) end
        end
    end)
end

local function stopLoop(key)
    if threads[key] then task.cancel(threads[key]) threads[key] = nil end
end

-- =============================================
--  HELPERS
-- =============================================
local function getPlayerPlot()
    return workspace:FindFirstChild("Plot_" .. player.Name)
end

local function findProximityPrompt()
    local plot = getPlayerPlot()
    if not plot then return nil end
    for _, obj in ipairs(plot:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == "Place Item" then
            return obj
        end
    end
    return nil
end

local function getToolFromBackpack()
    local backpack = player:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower() ~= "bat" then
                return tool
            end
        end
    end
    local char = player.Character
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower() ~= "bat" then
                return tool
            end
        end
    end
    return nil
end


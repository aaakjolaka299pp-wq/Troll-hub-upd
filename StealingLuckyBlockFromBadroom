-- AUTO UPGRADE BRAINROT
-- Display: 1-30 = Floor1/Slot1 - Floor3/Slot10, All = semua slot
local slotDisplayValues = {}
for i = 1, 30 do
    table.insert(slotDisplayValues, tostring(i))
end
table.insert(slotDisplayValues, "All")

local function getFloorSlot(displayNum)
    -- 1-10 = Floor1 Slot1-10, 11-20 = Floor2 Slot1-10, 21-30 = Floor3 Slot1-10
    local floor = math.ceil(displayNum / 10)
    local slot  = ((displayNum - 1) % 10) + 1
    return "Floor" .. floor, "Slot" .. slot
end

BuyRight:AddDropdown("UpgradeBrainrotSelector", {
    Values     = slotDisplayValues,
    Default    = 1,
    Multi      = true,
    Text       = "Slot (1-30 / All)",
    Searchable = false,
    Tooltip    = "1-10=Floor1, 11-20=Floor2, 21-30=Floor3. All=semua slot",
})

BuyRight:AddToggle("AutoUpgradeBrainrot", {
    Text    = "Auto Upgrade Brainrot",
    Default = false,
    Callback = function(Value)
        if Value then
            startLoop("AutoUpgradeBrainrot", function()
                local selected = Options.UpgradeBrainrotSelector.Value
                if selected["All"] then
                    -- upgrade semua slot
                    for i = 1, 30 do
                        local floor, slot = getFloorSlot(i)
                        pcall(function()
                            Events:WaitForChild("RequestSlotUpgrade"):FireServer(floor, slot)
                        end)
                    end
                else
                    for num, active in pairs(selected) do
                        if active and num ~= "All" then
                            local n = tonumber(num)
                            if n then
                                local floor, slot = getFloorSlot(n)
                                pcall(function()
                                    Events:WaitForChild("RequestSlotUpgrade"):FireServer(floor, slot)
                                end)
                            end
                        end
                    end
                end
            end, function() return Options.UpgradeBrainrotDelay.Value end)
        else
            stopLoop("AutoUpgradeBrainrot")
        end
    end,
})

BuyRight:AddSlider("UpgradeBrainrotDelay", {

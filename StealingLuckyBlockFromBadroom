-- AUTO DUPE
local placeItemRunning = false

local function runPlaceItem()
    while placeItemRunning do
        local prompt = findProximityPrompt()
        if not prompt then
            Library:Notify({ Title = "Rilz Hub", Description = "Place Item habis, berhenti.", Time = 3 })
            placeItemRunning = false
            Toggles.AutoDupe:SetValue(false)
            break
        end

        local char = player.Character
        if not char then task.wait(0.5) continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(0.5) continue end

        local promptPart = prompt.Parent
        local promptCFrame = promptPart:IsA("BasePart") and promptPart.CFrame or CFrame.new(promptPart.Position)
        hrp.CFrame = promptCFrame * CFrame.new(0, 0, -3)
        task.wait(0.1)

        local tool = getToolFromBackpack()
        if tool then
            player.Character.Humanoid:EquipTool(tool)
            task.wait(0.1)
        end

        char:FindFirstChildOfClass("Humanoid").Health = 0
        task.wait(0.3)

        local newChar = player.Character or player.CharacterAdded:Wait()
        task.wait(0.2)

        local freshPrompt = findProximityPrompt()
        if not freshPrompt then
            Library:Notify({ Title = "Rilz Hub", Description = "Place Item habis, berhenti.", Time = 3 })
            placeItemRunning = false
            Toggles.AutoDupe:SetValue(false)
            break
        end

        local newHRP = newChar:WaitForChild("HumanoidRootPart", 5)
        if not newHRP then task.wait(0.5) continue end

        local fp = freshPrompt.Parent
        local fpCFrame = fp:IsA("BasePart") and fp.CFrame or CFrame.new(fp.Position)
        newHRP.CFrame = fpCFrame * CFrame.new(0, 0, -3)
        task.wait(0.1)

        local ok = pcall(fireproximityprompt, freshPrompt)
        if not ok then pcall(function() freshPrompt.Triggered:Fire(player) end) end

        task.wait(0.3)
    end
end


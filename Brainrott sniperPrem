    -- Patch: library ini punya bug assign table ke TextLabel.Text
    -- Override __newindex untuk semua TextLabel agar auto-convert ke string
    local origNewIndex = getrawmetatable and getrawmetatable(Instance.new("TextLabel")).__newindex
    if origNewIndex then
        local mt = getrawmetatable(Instance.new("TextLabel"))
        local old = mt.__newindex
        setreadonly(mt, false)
        mt.__newindex = function(self, key, value)
            if key == "Text" and type(value) == "table" then
                local str = ""
                for k, v in pairs(value) do
                    if type(v) == "string" then str = v break end
                    if type(k) == "string" then str = k break end
                end
                return old(self, key, str)
            end
            return old(self, key, value)
        end
        setreadonly(mt, true)
    end


    local function matchesBrainrotName(model, targetSet)
        if next(targetSet) == nil then return true end
        local id = model:GetAttribute("BrainrotId")
        return targetSet[id] == true
    end

    local function getMutationType(model)
        local mutId = model:GetAttribute("BrainrotMutation")
        return MutationIdMap[mutId] or "normal"
    end

    local function matchesMutation(model, targetMutation)
        if targetMutation == "All" then return true end
        local mType = getMutationType(model)
        return mType == string.lower(targetMutation)
    end


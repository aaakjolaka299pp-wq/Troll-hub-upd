-- ========================
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function tpTo(pos)
    local hrp = getHRP()
    if hrp then hrp.CFrame = CFrame.new(pos) end
end

local function getMyPlot()
    local Plots = workspace:WaitForChild("Plots", 10)
    if not Plots then return nil end
    local attempts = 0
    while #Plots:GetChildren() == 0 and attempts < 20 do
        task.wait(0.5)
        attempts += 1
    end
    for _, plot in ipairs(Plots:GetChildren()) do
        local ownerAttr = plot:GetAttribute("Owner")
        if ownerAttr == player.Name or ownerAttr == tostring(player.UserId) then
            return plot
        end
    end
    for _, plot in ipairs(Plots:GetChildren()) do
        for _, desc in ipairs(plot:GetDescendants()) do
            if desc:IsA("TextLabel") and desc.Text == player.Name then
                return plot
            end
        end
    end
    return Plots:GetChildren()[1]
end

local cachedPlot, cachedStands = nil, nil

local function refreshPlotCache()
    cachedPlot, cachedStands = nil, nil
    local plot = getMyPlot()
    if not plot then return false end
    local stands = plot:FindFirstChild("Stands")
    if not stands then return false end
    cachedPlot, cachedStands = plot, stands
    return true
end

-- ========================
-- COLLECT CASH
-- ========================
local function collectCash()
    local hrp = getHRP()
    if not hrp then return end
    if not cachedPlot or not cachedPlot.Parent or not cachedStands or not cachedStands.Parent then
        if not refreshPlotCache() then return end
    end
    for _, stand in ipairs(cachedStands:GetChildren()) do
        local pad = stand:FindFirstChild("CollectPadHitbox")
        if pad and pad.Parent then
            pcall(function()
                firetouchinterest(hrp, pad, 0)
                firetouchinterest(hrp, pad, 1)
            end)
        end
    end
end

-- ========================
-- AUTO X2 TRAIN
-- ========================
local function equipBarbell()
    if barbellEquipped then return end
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return end
    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("barbell") then
            local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:EquipTool(tool)
                barbellEquipped = true
            end
            return
        end
    end
end

local function clickBonusButton()
    for _, gui in ipairs(player.PlayerGui:GetDescendants()) do
        if gui:IsA("ImageButton") and gui.Name == "bonus-button" and gui.Visible then
            pcall(function() firesignal(gui.MouseButton1Click) end)
            pcall(function() firesignal(gui.Activated) end)
        end
    end
end

-- ========================
-- AUTO TP
-- ========================
local function findZoneByMult(mult)
    local best, bestMult = nil, 0
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.Name == "BonusPowerZone" and obj:IsA("BasePart") then
            local m = obj:GetAttribute("multiplier") or 0
            if m == mult then return obj end
            if m > bestMult then best = obj; bestMult = m end
        end
    end
    return best
end

local function doTP(mult)
    local hrp = getHRP()
    if not hrp then return end
    local zone = findZoneByMult(mult)
    if not zone or not zone.Parent then return end
    if (hrp.Position - zone.Position).Magnitude > 8 then
        hrp.CFrame = CFrame.new(zone.Position + Vector3.new(0, 5, 0))
    end
end


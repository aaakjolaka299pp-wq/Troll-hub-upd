-- ========================
-- AUTO FAST GET BRAINROT
-- (7 loop paralel spam dari push_spam_fixed)
-- ========================
local brainrotLoops = {}

local function startBrainrotLoops()
    -- Loop 1: Spam TP Start
    brainrotLoops[1] = task.spawn(function()
        while State.AutoFastGetBrainrot do
            pcall(tpTo, START_POS)
            task.wait()
        end
    end)

    -- Loop 2: Spam Progress toggle
    brainrotLoops[2] = task.spawn(function()
        local s = true
        while State.AutoFastGetBrainrot do
            pcall(function() player:SetAttribute(ATTR_PROGRESS, s) end)
            s = not s
            task.wait()
        end
    end)

    -- Loop 3: Spam Confirm toggle
    brainrotLoops[3] = task.spawn(function()
        local s = true
        while State.AutoFastGetBrainrot do
            pcall(function() player:SetAttribute(ATTR_CONFIRM, s) end)
            s = not s
            task.wait()
        end
    end)

    -- Loop 4: Spam Begin remote
    brainrotLoops[4] = task.spawn(function()
        while State.AutoFastGetBrainrot do
            if beginRemote then
                pcall(function() beginRemote:FireServer(0, 1) end)
            end
            task.wait()
        end
    end)

    -- Loop 5: Spam TP End
    brainrotLoops[5] = task.spawn(function()
        while State.AutoFastGetBrainrot do
            pcall(tpTo, END_POS)
            task.wait()
        end
    end)

    -- Loop 6: Spam ReachedEnd remote
    brainrotLoops[6] = task.spawn(function()
        while State.AutoFastGetBrainrot do
            if reachedEnd then
                pcall(function() reachedEnd:FireServer() end)
            end
            task.wait()
        end
    end)

    -- Loop 7: Spam Hatch Anim false
    brainrotLoops[7] = task.spawn(function()
        while State.AutoFastGetBrainrot do
            pcall(function() player:SetAttribute(ATTR_HATCH, false) end)
            task.wait()
        end
    end)
end


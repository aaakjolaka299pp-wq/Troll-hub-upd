    lbl.Position = UDim2.new(0, 15, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = Color3.fromRGB(160, 160, 170)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 5

    local bar = Instance.new("Frame", btn)
    bar.Size = UDim2.new(0, 3, 1, -14)
    bar.Position = UDim2.new(0, 2, 0, 7)
    bar.BackgroundColor3 = Color3.fromRGB(255, 40, 70)
    bar.BackgroundTransparency = 1
    bar.BorderSizePixel = 0
    bar.ZIndex = 5
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    return btn, lbl, bar
end

local function selectTab(name)
    if activeTab == name then return end
    activeTab = name
    for n, data in pairs(tabs) do
        local isActive = (n == name)
        data.btn.BackgroundTransparency = isActive and 0.4 or 1
        data.lbl.TextColor3 = isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(160,160,170)
        data.bar.BackgroundTransparency = isActive and 0 or 1
    end
    for n, content in pairs(contents) do
        content.Visible = (n == name)
    end
end


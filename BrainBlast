local farmLoopThread = nil

MainLeft:AddToggle("AutoFarmLoop", {
    Text    = "Auto Farm Loop",
    Default = false,
    Tooltip = "Loop: TP Blast Zone → Klik blast → Auto Perfect → Klik tengah sampai dapat brainrot → TP lagi",
    Callback = function(state)
        if state then
            -- Aktifkan Auto Perfect otomatis saat farm loop ON

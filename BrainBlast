-- Teleport ke Blast Zone
local function teleportToBlastZone()
    local char    = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp     = char:FindFirstChild("HumanoidRootPart")
    local zones   = workspace:FindFirstChild("Zones")
    local blastZone = zones and zones:FindFirstChild("BlastZone")
    local blastArea = blastZone and (
        blastZone:FindFirstChild("BlastArea") or
        blastZone:FindFirstChild("SafeArea") or
        blastZone:FindFirstChild("Part")
    )
    if hrp and blastArea and blastArea:IsA("BasePart") then
        hrp.CFrame = blastArea.CFrame + Vector3.new(0, 5, 0)
        return true
    end
    return false
end

-- Cari blast button di PlayerGui pakai path exact
local function findBlastButton()
    local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD")
    if not hud then return nil end
    local blastFrame = hud:FindFirstChild("BlastFrame")
    if not blastFrame then return nil end
    local btn = blastFrame:FindFirstChild("BlastButton")
    if btn and btn.Visible then return btn end
    return nil
end


-- Cek apakah brainrot sudah masuk backpack / character
local brainrotConnections = {}
local brainrotObtained    = false

local function listenBrainrot(callback)
    for _, c in ipairs(brainrotConnections) do c:Disconnect() end
    brainrotConnections = {}
    brainrotObtained    = false

    local function onChild(child)
        if not child or not child.Name then return end
        local n = child.Name:lower()
        if n:find("brainrot") or n:find("brain rot") then
            brainrotObtained = true
            if callback then callback(child.Name) end
        end
    end

    local backpack = LocalPlayer:WaitForChild("Backpack")
    table.insert(brainrotConnections, backpack.ChildAdded:Connect(onChild))

    if LocalPlayer.Character then
        table.insert(brainrotConnections, LocalPlayer.Character.ChildAdded:Connect(onChild))
    end
    table.insert(brainrotConnections, LocalPlayer.CharacterAdded:Connect(function(char)
        table.insert(brainrotConnections, char.ChildAdded:Connect(onChild))
    end))
end

local function stopListenBrainrot()
    for _, c in ipairs(brainrotConnections) do c:Disconnect() end
    brainrotConnections = {}
    brainrotObtained    = false
end


            end

local VirtualInputManager = game:GetService("VirtualInputManager")

local function sendCenterClick()
    local camera = workspace.CurrentCamera
    if not camera then return end
    local vp = camera.ViewportSize
    local cx  = vp.X / 2
    local cy  = vp.Y / 2
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
    end)
end

local clickLoopThread = nil

local function startClickLoop()
    if clickLoopThread then task.cancel(clickLoopThread) end
    clickLoopThread = task.spawn(function()
        while clickLoopThread ~= nil do
            sendCenterClick()
            task.wait(0.1)
        end
    end)
end

local function stopClickLoop()
    if clickLoopThread then
        task.cancel(clickLoopThread)
        clickLoopThread = nil
    end
end

            farmLoopThread = task.spawn(function()
                -- Jalankan auto click loop terus menerus di background
                startClickLoop()

                while Toggles["AutoFarmLoop"] and Toggles["AutoFarmLoop"].Value do
                    pcall(function()
                        -- Step 1: TP ke Blast Zone
                        local tpOk = teleportToBlastZone()
                        if not tpOk then
                            Library:Notify({ Title = "Rilzz Hub", Description = "Blast Zone tidak ditemukan, retry...", Time = 2 })
                            task.wait(1)
                            return
                        end
                        task.wait(0.5)

                        -- Step 2: Pasang listener brainrot
                        brainrotObtained = false
                        listenBrainrot(function(name)
                            Library:Notify({ Title = "Brainrot!", Description = "Dapat: " .. name, Time = 2 })
                        end)

                        -- Step 3: Tunggu sampai brainrot dapat (tanpa batas waktu)
                        while not brainrotObtained
                        and Toggles["AutoFarmLoop"]
                        and Toggles["AutoFarmLoop"].Value do
                            task.wait(0.1)
                        end

                        stopListenBrainrot()

                        -- Step 4: TP kembali ke Blast Zone (next loop)
                        task.wait(0.3)
                    end)
                end

                -- Hentikan click loop saat farm loop berhenti
                stopClickLoop()

                -- Matikan Auto Perfect saat loop berhenti
                LocalPlayer:SetAttribute("GP_AutoPerfect", false)
                if Toggles["AutoPerfect"] then
                    Toggles["AutoPerfect"]:SetValue(false)
                end
            end)
        else
            if farmLoopThread then
                task.cancel(farmLoopThread)
                farmLoopThread = nil
            end
            -- Matikan Auto Perfect
            LocalPlayer:SetAttribute("GP_AutoPerfect", false)
            if Toggles["AutoPerfect"] then
                Toggles["AutoPerfect"]:SetValue(false)
            end
            stopListenBrainrot()
            Library:Notify({ Title = "Rilzz Hub", Description = "Auto Farm Loop berhenti.", Time = 2 })
        end
    end,
})




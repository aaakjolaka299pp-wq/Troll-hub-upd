                                    UpgradeBrainEvent:FireServer(g .. "_" .. i)
                                end)
                                task.wait(0.05)
                            end
                        end
                    end
                else
                    -- Tidak ada yang dipilih = upgrade semua
                    for group = 1, 3 do
                        for index = 1, 8 do
                            pcall(function()
                                UpgradeBrainEvent:FireServer(group .. "_" .. index)
                            end)
                            task.wait(0.05)
                        end
                    end
                end
            end, function() return Options.AutoUpgradeBrainrotDelay.Value end)
        else
            stopLoop("AutoUpgradeBrainrot")
        end
    end,
})

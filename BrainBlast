-- TRAINING ZONE
local selectedZones  = { ["X2"] = true }
local zoneConnection = nil

local ZONE_MAP = {
    ["X1.5"] = "X1.5TrainingZone",
    ["X2"]   = "X2TrainingZone",
    ["X3"]   = "X3TrainingZone",
}

local function startTrackingZone(zoneInstance)
    if zoneConnection then zoneConnection:Disconnect() zoneConnection = nil end
    if not zoneInstance then return end
    zoneConnection = RunService.Stepped:Connect(function()
        if not zoneInstance or not zoneInstance.Parent then
            if zoneConnection then zoneConnection:Disconnect() zoneConnection = nil end
            return
        end
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local targetCFrame
        if zoneInstance:IsA("Model") then
            targetCFrame = zoneInstance:GetPivot() * CFrame.new(0, 10, 0)
        elseif zoneInstance:IsA("BasePart") then
            targetCFrame = zoneInstance.CFrame * CFrame.new(0, 10, 0)
        end
        if targetCFrame then hrp.CFrame = targetCFrame end
    end)
end

local function findAndTrackZones()
    for displayName, active in pairs(selectedZones) do
        if active then
            local zoneName = ZONE_MAP[displayName]
            local existing = workspace:FindFirstChild(zoneName)
            if existing then
                startTrackingZone(existing)
                return
            end
        end
    end
end


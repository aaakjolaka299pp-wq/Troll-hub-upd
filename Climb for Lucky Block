-- ==================== COLLECT CASH ====================
local function Cash()
    task.spawn(function()
        _G.Cash = true
        while _G.Cash do
            pcall(function()
                local LocalPlayer = game:GetService("Players").LocalPlayer
                local Plot = LocalPlayer:GetAttribute("Plot")
                local PlotBase = workspace.Plots[Plot].Base
                local hrp = LocalPlayer.Character.HumanoidRootPart

                -- Cari "Collect" di SELURUH Base, tidak peduli struktur sub-folder
                -- karena struktur Base[1]/Base[2]/Base[3] bisa beda tiap server
                for _, obj in pairs(PlotBase:GetDescendants()) do
                    if obj.Name == "Collect" then
                        firetouchinterest(hrp, obj, 0)
                        task.wait(0.1)
                        firetouchinterest(hrp, obj, 1)
                        task.wait(0.1)
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

Climb:AddToggle({
    text = "Collect Cash",
    flag = "toggle3",
    state = false,
    callback = function(state)
        _G.Cash = state
        if state then Cash() end
    end
})

-- ==================== UPGRADE ALL ====================
local function Upgrade()
    task.spawn(function()
        _G.Upgrade = true
        while _G.Upgrade do
            pcall(function()
                local Animal = game:GetService("ReplicatedStorage").Remote.Event.Animal
                local TryUpgradeAnimal = Animal:FindFirstChild("[C-S]TryUpgradeAnimal")

                for i = 1, 30 do
                    TryUpgradeAnimal:FireServer(tostring(i))
                    task.wait(0.1)
                end
            end)
            task.wait(1)
        end
    end)
end


-- ==================== OP LUCKY BLOCK ====================
local function Block()
    task.spawn(function()
        _G.Block = true
        while _G.Block do
            pcall(function()
                local LocalPlayer = game.Players.LocalPlayer
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local Bottom = workspace.World.Bottom
                hrp.CFrame = Bottom:GetPivot() * CFrame.new(-30, 0, 0)
                task.wait(0.5)

                local Summon = game:GetService("ReplicatedStorage").Remote.Event.Summon
                local OpenJackpot = Summon:FindFirstChild("[C-S]OpenJackpot")
                OpenJackpot:FireServer("Box11", 18)
            end)
            task.wait(0.1)
        end
    end)
end

Climb:AddToggle({
    text = "OP Lucky Block",
    flag = "toggle",
    state = false,
    callback = function(state)
        _G.Block = state
        if state then Block() end
    end
})


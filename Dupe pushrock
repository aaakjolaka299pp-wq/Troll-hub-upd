-- Total fire counter (lifetime)
local totalFired = 0

-- ─────────────────────────────────────────────
-- DUPE LOGIC — cooldown dikurangin + fire amount kali
-- ─────────────────────────────────────────────
local COOLDOWN = 0.15  -- dikurangin dari 2 detik → 0.15 detik
local cooldown = false

DupeBtn.MouseButton1Click:Connect(function()
    if cooldown then return end
    cooldown = true

    local amount = amountValue
    BtnLabel.Text = "⚡  FIRING x" .. amount .. "..."
    StatusLabel.Text = "[ INJECTING · x" .. amount .. " ]"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)

    -- Flash
    DupeBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    TweenService:Create(DupeBtn, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(0, 180, 220)
    }):Play()

    -- Fire sebanyak amount
    task.spawn(function()
        local evt = getEvent("setCharacterToSpotEvent")
        for i = 1, amount do
            pcall(function()
                if evt then evt:FireServer(0/0) end
            end)
            totalFired += 1
            FireCount.Text = "FIRED: " .. totalFired

            -- Progress bar update
            ProgressFill.Size = UDim2.new(i / amount, 0, 1, 0)

            task.wait(0.05)  -- jeda antar fire (50ms)
        end

        -- Selesai
        ProgressFill.Size = UDim2.new(1, 0, 1, 0)
        BtnLabel.Text = "✓  DONE x" .. amount
        StatusLabel.Text = "[ SUCCESS · " .. amount .. " FIRED ]"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 140)

        task.wait(COOLDOWN)

        -- Reset
        ProgressFill.Size = UDim2.new(0, 0, 1, 0)
        BtnLabel.Text = "⚡  EXECUTE DUPE"
        StatusLabel.Text = "[ READY ]"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 180, 220)
        cooldown = false
    end)
end)


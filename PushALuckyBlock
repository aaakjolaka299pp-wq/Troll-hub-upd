            PingLabel.Text = "Ping: " .. ping .. "ms"
            PingLabel.BackgroundColor3 = ping < 100 and Color3.fromRGB(40, 180, 80)
                or ping < 200 and Color3.fromRGB(220, 140, 0)
                or Color3.fromRGB(255, 40, 70)
        end
        task.wait(2)
    end
end)

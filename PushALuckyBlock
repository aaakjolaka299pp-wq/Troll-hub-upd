-- ========================
-- AUTO BRAINROT
-- Alur: begin → tween ke end pos → tunggu push-zone ON → tunggu push-zone OFF → loop
-- ========================
local BRAINROT_END    = Vector3.new(2.9,  524.7, 2022.9)
local BRAINROT_RETURN = Vector3.new(0.7,   33.3,  189.0)

local function doBrainrotLoop()
    while State.AutoBrainrot do
        if not beginRemote then task.wait(0.2); continue end

        -- Step 1: Fire begin
        pcall(function() beginRemote:FireServer(0, 1) end)

        -- Step 2: Tween cepat ke end position
        local hrp = getHRP()
        if hrp then
            local tween = TweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(BRAINROT_END)
            })
            tween:Play()
            tween.Completed:Wait()
        end

        if not State.AutoBrainrot then break end

        -- Step 3: Tunggu push-progress ON (max 15 detik)
        local t = tick()
        while State.AutoBrainrot and not player:GetAttribute("push-in-progress") do
            if tick() - t > 15 then break end
            task.wait(0.05)
        end

        if not State.AutoBrainrot then break end

        -- Step 4: Tunggu push-progress OFF (max 30 detik)
        t = tick()
        while State.AutoBrainrot and player:GetAttribute("push-in-progress") do
            if tick() - t > 30 then break end
            task.wait(0.05)
        end

        if not State.AutoBrainrot then break end

        -- Step 5: TP ke return position
        hrp = getHRP()
        if hrp then
            hrp.CFrame = CFrame.new(BRAINROT_RETURN)
        end

        if not State.AutoBrainrot then break end

        -- Step 6: Tunggu push-zone ON (max 15 detik)
        t = tick()
        while State.AutoBrainrot and not player:GetAttribute("push-zone") do
            if tick() - t > 15 then break end
            task.wait(0.05)
        end

        if not State.AutoBrainrot then break end

        -- Step 7: Tunggu push-zone OFF (max 30 detik)
        t = tick()
        while State.AutoBrainrot and player:GetAttribute("push-zone") do
            if tick() - t > 30 then break end
            task.wait(0.05)
        end

        -- Step 8: Langsung loop ulang
    end
end

